graph TB
    subgraph FRONTEND["🖥️ FRONTEND — React + Vite + TypeScript"]
        direction TB
        UI["UI Components<br/>(Radix UI / shadcn/ui)<br/>Tailwind CSS"]
        PAGES["Pages"]
        HOOKS["Hooks<br/>(useAuth, useTheme, use-toast)"]
        LIB["Lib<br/>(auto-correction.ts, ia.ts)"]
        ROUTER["React Router DOM"]
        RQ["React Query<br/>(TanStack)"]
        
        ROUTER --> PAGES
        PAGES --> UI
        PAGES --> HOOKS
        PAGES --> RQ
        PAGES --> LIB
    end

    subgraph BACKEND["⚙️ BACKEND — Node.js + Express"]
        direction TB
        APIB["API REST Express<br/>:3000"]
        AUTH["Auth Module<br/>(JWT + bcrypt)"]
        MIDDLEWARE["Middlewares<br/>(auth, roles, validation)"]
        CONTROLLERS["Controllers<br/>(exams, questions, submissions,<br/>users, classes, notifications)"]
        SERVICES["Services<br/>(Business Logic)"]
        ORM["ORM / Query Builder<br/>(Prisma ou Knex.js)"]
        
        APIB --> MIDDLEWARE
        MIDDLEWARE --> CONTROLLERS
        CONTROLLERS --> SERVICES
        SERVICES --> ORM
        SERVICES --> AUTH
    end

    subgraph DATABASE["🗄️ BASE DE DONNÉES — PostgreSQL"]
        direction TB
        DB["PostgreSQL"]
        TABLES["Tables:<br/>profiles, user_roles, subjects,<br/>levels, classes, class_students,<br/>questions, exams, exam_questions,<br/>submissions, answers, notifications"]
        MIGRATIONS["Migrations SQL"]
        
        DB --- TABLES
        DB --- MIGRATIONS
    end

    subgraph IA["🤖 IA — FastAPI + Python"]
        direction TB
        API["FastAPI Server<br/>:8000"]
        ENGINE["CorrectionEngine<br/>(Routeur principal)"]
        QCM["QCMCorrector<br/>Comparaison directe"]
        CALC["CalculCorrector<br/>SymPy"]
        COURTE["CourteCorrector<br/>Sentence Transformers"]
        LONGUE["LongueCorrector<br/>Ollama (LLM)"]
        PDF["Extraction PDF<br/>PyPDF2 + LLM"]
        
        API --> ENGINE
        API --> PDF
        ENGINE --> QCM
        ENGINE --> CALC
        ENGINE --> COURTE
        ENGINE --> LONGUE
    end

    FRONTEND -->|"HTTP REST<br/>(Axios / Fetch)<br/>JWT Bearer Token"| APIB
    ORM -->|"SQL Queries"| DB
    SERVICES -->|"HTTP POST<br/>localhost:8000/api/*"| API
    LONGUE -->|"ollama.chat()"| OLLAMA["🦙 Ollama<br/>llama3.2 / mistral<br/>:11434"]
    COURTE -->|"embeddings"| ST["🧠 Sentence<br/>Transformers"]

    style FRONTEND fill:#1e3a5f,stroke:#4a90d9,color:#fff
    style BACKEND fill:#8b4513,stroke:#d2691e,color:#fff
    style DATABASE fill:#2d5016,stroke:#6abf40,color:#fff
    style IA fill:#5c1a5c,stroke:#c056c0,color:#fff
    style OLLAMA fill:#4a3000,stroke:#f0a030,color:#fff
    style ST fill:#4a3000,stroke:#f0a030,color:#fff
    
    %% Style des flèches en blanc
    linkStyle default stroke:#ffffff,stroke-width:2px,color:#ffffff
